[gd_resource type="Resource" script_class="WeaponData" load_steps=28 format=3]

[ext_resource type="Script" path="res://scripts/data/weapon_data.gd" id="1_spark"]
[ext_resource type="Texture2D" path="res://assets/art/weapons/icons_sliced/icon_20.png" id="2_icon"]
[ext_resource type="Script" path="res://scripts/data/weapon_path.gd" id="3_path"]
[ext_resource type="Script" path="res://scripts/data/weapon_path_level.gd" id="4_level"]

[sub_resource type="Resource" id="Resource_spark_blast_l2"]
script = ExtResource("4_level")
level = 2
damage_bonus = 3
description = "伤害+3"
[sub_resource type="Resource" id="Resource_spark_blast_l3"]
script = ExtResource("4_level")
level = 3
damage_bonus = 0
special_tag = &"spark_overload"
description = "爆炸伤害+4"
[sub_resource type="Resource" id="Resource_spark_blast_l4"]
script = ExtResource("4_level")
level = 4
range_bonus = 20
description = "射程+20"
[sub_resource type="Resource" id="Resource_spark_blast_l5"]
script = ExtResource("4_level")
level = 5
damage_bonus = 0
special_tag = &"spark_wide"
description = "爆炸范围+20"
[sub_resource type="Resource" id="Resource_spark_blast_l6"]
script = ExtResource("4_level")
level = 6
damage_bonus = 4
description = "伤害+4"
[sub_resource type="Resource" id="Resource_spark_blast_l7"]
script = ExtResource("4_level")
level = 7
cooldown_bonus = -0.2
description = "冷却-0.2秒"
[sub_resource type="Resource" id="Resource_spark_blast_l8"]
script = ExtResource("4_level")
level = 8
damage_bonus = 6
special_tag = &"spark_supernova"
description = "伤害+6，爆炸范围大幅提升"
[sub_resource type="Resource" id="Resource_spark_path_blast"]
script = ExtResource("3_path")
path_id = &"blast"
display_name = "爆裂"
description = "追求高爆发和大爆炸"
levels = Array[ExtResource("4_level")]([SubResource("Resource_spark_blast_l2"), SubResource("Resource_spark_blast_l3"), SubResource("Resource_spark_blast_l4"), SubResource("Resource_spark_blast_l5"), SubResource("Resource_spark_blast_l6"), SubResource("Resource_spark_blast_l7"), SubResource("Resource_spark_blast_l8")])

