[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/upgrade_select.gd" id="1_select"]

[node name="UpgradeSelect" type="CanvasLayer" groups=["upgrade_select"]]
process_mode = 3
visible = false
script = ExtResource("1_select")

[node name="PanelContainer" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -400.0
offset_top = -230.0
offset_right = 400.0
offset_bottom = 230.0

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "升级选择"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32

[node name="OptionsContainer" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
alignment = 1
theme_override_constants/separation = 24

[node name="ActionsContainer" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 18

[node name="RerollButton" type="Button" parent="PanelContainer/VBoxContainer/ActionsContainer"]
custom_minimum_size = Vector2(180, 44)
layout_mode = 2
text = "刷新卡片"

[node name="SkipButton" type="Button" parent="PanelContainer/VBoxContainer/ActionsContainer"]
custom_minimum_size = Vector2(180, 44)
layout_mode = 2
text = "跳过本次"

[connection signal="pressed" from="PanelContainer/VBoxContainer/ActionsContainer/RerollButton" to="." method="_on_reroll_pressed"]
[connection signal="pressed" from="PanelContainer/VBoxContainer/ActionsContainer/SkipButton" to="." method="_on_skip_pressed"]
