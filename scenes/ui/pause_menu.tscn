[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/pause_menu.gd" id="1_pm"]

[node name="PauseMenu" type="CanvasLayer"]
process_mode = 3
visible = false
script = ExtResource("1_pm")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -240.0
offset_top = -220.0
offset_right = 240.0
offset_bottom = 220.0

[node name="VBoxContainer" type="VBoxContainer" parent="Panel"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "暂停"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 40

[node name="StatsLabel" type="Label" parent="Panel/VBoxContainer"]
layout_mode = 2
text = "存活时间 00:00    击杀 0"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.75, 0.75, 0.8, 1)

[node name="WeaponsSection" type="VBoxContainer" parent="Panel/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="WeaponsTitle" type="Label" parent="Panel/VBoxContainer/WeaponsSection"]
layout_mode = 2
text = "当前武器"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16
theme_override_colors/font_color = Color(0.85, 0.85, 0.9, 1)

[node name="WeaponsContainer" type="HBoxContainer" parent="Panel/VBoxContainer/WeaponsSection"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 6

[node name="Spacer" type="Control" parent="Panel/VBoxContainer"]
custom_minimum_size = Vector2(0, 16)
layout_mode = 2

[node name="ResumeButton" type="Button" parent="Panel/VBoxContainer"]
custom_minimum_size = Vector2(200, 48)
layout_mode = 2
text = "继续游戏"

[node name="QuitButton" type="Button" parent="Panel/VBoxContainer"]
custom_minimum_size = Vector2(200, 48)
layout_mode = 2
text = "返回主菜单"

[connection signal="pressed" from="Panel/VBoxContainer/ResumeButton" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="Panel/VBoxContainer/QuitButton" to="." method="_on_quit_pressed"]
