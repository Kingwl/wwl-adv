[resource]
script = ExtResource("1_spark")
id = &"spark_bomb"
display_name = "火花弹"
description = "发射火花弹，命中后小范围爆炸"
weapon_type = 1
category = 0
damage = 10
cooldown = 2.0
range = 260.0
projectile_speed = 240.0
projectile_count = 1
pierce = 0
heal_amount = 0
orbit_count = 0
reflect_percent = 0.0
field_radius = 70.0
acquire_range = 0.0
tags = Array[StringName]([&"弹体", &"爆炸"])
icon = ExtResource("2_icon")
max_level = 8
paths = Array[ExtResource("3_path")]([SubResource("Resource_spark_path_blast"), SubResource("Resource_spark_path_scatter"), SubResource("Resource_spark_path_elec")])
