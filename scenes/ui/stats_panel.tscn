[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/stats_panel.gd" id="1_sp"]

[node name="StatsPanel" type="CanvasLayer"]
process_mode = 3
visible = false
script = ExtResource("1_sp")

[node name="Panel" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -240.0
offset_top = -340.0
offset_right = 240.0
offset_bottom = 340.0

[node name="ScrollContainer" type="ScrollContainer" parent="Panel"]
layout_mode = 2
follow_focus = true

[node name="VBoxContainer" type="VBoxContainer" parent="Panel/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Panel/ScrollContainer/VBoxContainer"]
layout_mode = 2
text = "属性面板"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 32

[node name="BasicSection" type="VBoxContainer" parent="Panel/ScrollContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="BasicTitle" type="Label" parent="Panel/ScrollContainer/VBoxContainer/BasicSection"]
layout_mode = 2
text = "基础属性"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.85, 0.85, 0.9, 1)

[node name="GridContainer" type="GridContainer" parent="Panel/ScrollContainer/VBoxContainer/BasicSection"]
layout_mode = 2
columns = 2
theme_override_constants/h_separation = 24
theme_override_constants/v_separation = 6

[node name="HSeparator" type="HSeparator" parent="Panel/ScrollContainer/VBoxContainer"]
layout_mode = 2

[node name="WeaponsSection" type="VBoxContainer" parent="Panel/ScrollContainer/VBoxContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="WeaponsTitle" type="Label" parent="Panel/ScrollContainer/VBoxContainer/WeaponsSection"]
layout_mode = 2
text = "武器详情"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.85, 0.85, 0.9, 1)

[node name="WeaponsList" type="VBoxContainer" parent="Panel/ScrollContainer/VBoxContainer/WeaponsSection"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="CloseButton" type="Button" parent="Panel/ScrollContainer/VBoxContainer"]
custom_minimum_size = Vector2(160, 44)
layout_mode = 2
size_flags_horizontal = 4
text = "关闭"

[connection signal="pressed" from="Panel/ScrollContainer/VBoxContainer/CloseButton" to="." method="_on_close_pressed"]
